# Never Play Alone validator environment template.
# Usage:
#   ./scripts/validator_setup.sh   # creates .env from this template if missing
#   # then edit NPA_BT_WALLET_DIR / NPA_WALLET / NPA_HOTKEY
#   # set OPENROUTER_API_KEY and CHUTES_API_KEY for the proxy/task generation
#   set -a; source .env; set +a
#   .venv/bin/npa-validator

# ── Bittensor identity ──────────────────────────────────────────────
# Wallet name + hotkey you registered on netuid 98.
# Absolute path to the wallet directory created by btcli.
# Optional when your wallet already lives under the Bittensor default path.
NPA_BT_WALLET_DIR=/home/your-user/.bittensor
NPA_WALLET=validator
NPA_HOTKEY=hk1
NPA_NETWORK=finney
# Netuid. Defaults to 98 (mainnet); override for testnet (e.g. NPA_NETUID=490).
# NPA_NETUID=98

# ── Backend ─────────────────────────────────────────────────────────
NPA_API_URL=https://api.neverplayalone.ai
NPA_API_TIMEOUT_SECONDS=180

# ── PM2 / updater ───────────────────────────────────────────────────
# Used by scripts/validator_autoupdate.sh and scripts/validator_update.sh.
# This is the validator app name. The updater app can be named separately
# with PM2's --name option, e.g. validator-updater.
NPA_VALIDATOR_PM2_NAME=validator
NPA_AUTOSTART_VALIDATOR=1

# ── npabench evaluation ─────────────────────────────────────────────
# The validator process runs on the host. npabench still uses Docker to launch
# Minecraft servers and sandboxed agents.
NPA_MISSION_ID=resource_gathering
NPA_LOOP_POLL_SECONDS=12
NPA_WEIGHT_EPOCH_BLOCKS=360
NPA_EVALUATION_START_CUTOFF_RATIO=0.5
NPA_MAX_PARALLEL_AGENTS=4
# Task instances (distinct seeds) evaluated per miner per round. The scoreboard
# score is the mean across these tasks, which smooths per-seed luck. Keep this the
# same on every validator (it is a fixed default). Note: evaluation time and LLM
# spend scale ~linearly with this value.
NPA_TASKS_PER_ROUND=3

# ── Emission / burn ─────────────────────────────────────────────────
# This validator sets its own weights; the burn is decided here, not by the
# backend. NPA_BURN_RATE is the fraction of weight sent to NPA_BURN_UID (the
# subnet owner) instead of the round winner. 0.0 = winner-take-all. Use
# 0.90–0.95 during the bootstrap/validate phase, then 0.0 for real emission.
NPA_BURN_RATE=0.9
# UID that receives the burned share (the subnet owner; UID 0 on netuid 98).
NPA_BURN_UID=0

# ── LLM proxy ───────────────────────────────────────────────────────
# Every round runs an egress-proxy container attached to the sandbox networks.
# Agents reach it by container DNS and get an OpenAI-compatible endpoint (via
# injected OPENROUTER_BASE_URL/OPENAI_BASE_URL); the real key stays in the
# container and each run has a hard spend cap.
# Production validators should fund both OPENROUTER_API_KEY and CHUTES_API_KEY.
# One key works only for local/single-provider testing. These keys are also read
# by npabench task generation below.
OPENROUTER_API_KEY=
CHUTES_API_KEY=
# Container-internal port the proxy listens on (never published to the host).
NPA_PROXY_PORT=8080
# Allowed models + cross-provider mapping are pinned in docker/proxy/model_pairs.json:
# agents may use either provider's id, the proxy routes to the matching funded
# provider and rejects models not listed. Edit that file to change the allowlist.
# Spend cap (USD) applied to each miner evaluation *per task*. With
# NPA_TASKS_PER_ROUND task sessions, total budget per miner per round is
# NPA_TASKS_PER_ROUND x this value.
NPA_PROXY_MAX_TOTAL_SPEND_USD=0.01
# Per-model prices are pinned in docker/proxy/model_pairs.json (see above).

# ── npabench task generation ────────────────────────────────────────
# The resource_gathering mission generates its prompt via an OpenAI-compatible
# provider. Provider: openrouter (default) or chutes — reuses OPENROUTER_API_KEY /
# CHUTES_API_KEY above. NPABENCH_PROMPT_MODEL must match the provider's model ids
# (e.g. openai/gpt-4.1-mini on OpenRouter).
NPABENCH_PROMPT_PROVIDER=openrouter
NPABENCH_PROMPT_MODEL=openai/gpt-4.1-mini
# For Chutes instead (model ids are Hugging-Face style):
# NPABENCH_PROMPT_PROVIDER=chutes
# NPABENCH_PROMPT_MODEL=deepseek-ai/DeepSeek-V3-0324
NPABENCH_PROMPT_TEMPERATURE=0
NPABENCH_PROMPT_MAX_TOKENS=180
NPABENCH_PROMPT_TIMEOUT_SECONDS=8

# ── Logging ─────────────────────────────────────────────────────────
NPA_LOG_LEVEL=INFO
