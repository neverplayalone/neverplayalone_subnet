# Never Play Alone validator — local environment template.
# Copy to .env and edit before running `docker compose up`.
# (.env is git-ignored.)

# ── Bittensor identity ──────────────────────────────────────────────
# Wallet name + hotkey you registered on netuid 490 (testnet).
# Absolute host path to the wallet directory created by btcli.
NPA_BT_WALLET_DIR=/home/your-user/.bittensor
NPA_WALLET=validator
NPA_HOTKEY=hk1
NPA_NETWORK=test
# Netuid is fixed by the subnet; do not change.
# NPA_NETUID=490

# ── Backend ─────────────────────────────────────────────────────────
NPA_API_URL=https://api.neverplayalone.ai

# ── mcbench evaluation ──────────────────────────────────────────────
NPA_MISSION_ID=resource_gathering
NPA_LOOP_POLL_SECONDS=12
NPA_MAX_PARALLEL_AGENTS=2

# ── Chutes LLM proxy (injects an OpenAI-compatible endpoint into miner
#    sandboxes and enforces a per-run spend cap) ────────────────────
# Enable only when miners need an OpenAI-compatible Chutes proxy.
CHUTES_API_KEY=
NPA_PROXY_ENABLED=0
NPA_PROXY_PORT=18080
# Bind on all interfaces so miner sandboxes can reach the proxy through the
# host's published port via host.docker.internal:host-gateway.
NPA_PROXY_BIND_HOST=0.0.0.0
# Optional Chutes model allowlist (comma-separated).
NPA_PROXY_ALLOWED_MODELS=
# Per-run spend cap (USD) applied to each miner evaluation.
NPA_PROXY_MAX_TOTAL_SPEND_USD=1.0
# Fallback token prices (USD per 1M tokens) when a model isn't in the
# explicit pricing JSON. 0 disables price-based budgeting for unknown models.
NPA_PROXY_DEFAULT_INPUT_PRICE_PER_1M_USD=0
NPA_PROXY_DEFAULT_OUTPUT_PRICE_PER_1M_USD=0
# Optional per-model pricing: {"model-name":{"input_per_1m_usd":1,"output_per_1m_usd":2}}
NPA_PROXY_MODEL_PRICES_JSON=

# ── Logging ─────────────────────────────────────────────────────────
NPA_LOG_LEVEL=INFO
