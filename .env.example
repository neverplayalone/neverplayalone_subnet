# Never Play Alone validator environment template.
# Usage:
#   ./scripts/validator_setup.sh   # creates .env from this template if missing
#   # then edit NPA_BT_WALLET_DIR / NPA_WALLET / NPA_HOTKEY
#   # enable the proxy only when you have OPENROUTER_API_KEY
#   set -a; source .env; set +a
#   .venv/bin/npa-validator

# ── Bittensor identity ──────────────────────────────────────────────
# Wallet name + hotkey you registered on netuid 98.
# Absolute path to the wallet directory created by btcli.
# Optional when your wallet already lives under the Bittensor default path.
NPA_BT_WALLET_DIR=/home/your-user/.bittensor
NPA_WALLET=validator
NPA_HOTKEY=hk1
NPA_NETWORK=finney
# Netuid is fixed by the subnet; do not change.
# NPA_NETUID=98

# ── Backend ─────────────────────────────────────────────────────────
NPA_API_URL=https://api.neverplayalone.ai

# ── npabench evaluation ─────────────────────────────────────────────
# The validator process runs on the host. npabench still uses Docker to launch
# Minecraft servers and sandboxed agents.
NPA_MISSION_ID=resource_gathering
NPA_LOOP_POLL_SECONDS=12
NPA_MAX_PARALLEL_AGENTS=2

# ── Emission / burn ─────────────────────────────────────────────────
# This validator sets its own weights; the burn is decided here, not by the
# backend. NPA_BURN_RATE is the fraction of weight sent to NPA_BURN_UID (the
# subnet owner) instead of the round winner. 0.0 = winner-take-all. Use
# 0.90–0.95 during the bootstrap/validate phase, then 0.0 for real emission.
NPA_BURN_RATE=0.9
# UID that receives the burned share (the subnet owner; UID 0 on netuid 98).
NPA_BURN_UID=0

# ── LLM proxy ───────────────────────────────────────────────────────
# When enabled, each round runs an egress-proxy container attached to the
# sandbox networks. Agents reach it by container DNS and get an OpenAI-
# compatible endpoint (via injected OPENROUTER_BASE_URL/OPENAI_BASE_URL); the
# real key stays in the container and each run has a hard spend cap.
# Enable only when miners need LLM access.
OPENROUTER_API_KEY=
NPA_PROXY_ENABLED=0
# OpenRouter API base URL (rarely changed).
# NPA_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Container-internal port the proxy listens on (never published to the host).
NPA_PROXY_PORT=8080
# Optional model allowlist (comma-separated, e.g. openai/gpt-4o-mini). Leave
# empty to allow any model the upstream provider offers.
NPA_PROXY_ALLOWED_MODELS=
# Per-run spend cap (USD) applied to each miner evaluation.
NPA_PROXY_MAX_TOTAL_SPEND_USD=1.0
# Fallback token prices (USD per 1M tokens) when a model isn't in the
# explicit pricing JSON. 0 disables price-based budgeting for unknown models.
NPA_PROXY_DEFAULT_INPUT_PRICE_PER_1M_USD=0
NPA_PROXY_DEFAULT_OUTPUT_PRICE_PER_1M_USD=0
# Optional per-model pricing: {"model-name":{"input_per_1m_usd":1,"output_per_1m_usd":2}}
NPA_PROXY_MODEL_PRICES_JSON=

# ── Logging ─────────────────────────────────────────────────────────
NPA_LOG_LEVEL=INFO
